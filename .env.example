AUMOS_SERVICE_NAME=aumos-fidelity-validator
AUMOS_LOG_LEVEL=info
AUMOS_DATABASE__URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_fidelity
AUMOS_KAFKA__BOOTSTRAP_SERVERS=localhost:9092
AUMOS_REDIS__URL=redis://localhost:6379/0
AUMOS_MINIO__ENDPOINT=localhost:9000
AUMOS_MINIO__ACCESS_KEY=minioadmin
AUMOS_MINIO__SECRET_KEY=minioadmin
AUMOS_FVL_CERTIFICATE_BUCKET=fidelity-certificates
AUMOS_FVL_DATASET_BUCKET=validation-datasets
AUMOS_FVL_MAX_SAMPLE_ROWS=100000
AUMOS_FVL_PRIVACY_ATTACK_ITERATIONS=1000
AUMOS_FVL_MEMORIZATION_SHADOW_MODELS=10
AUMOS_FVL_REPORT_EXPIRY_DAYS=90
